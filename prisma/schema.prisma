generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum FeedbackType {
  BUG
  FEATURE
  GENERAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum UserRole {
  ADMIN
  MANAGER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Feedback {
  id          String       @id @default(cuid())
  type        FeedbackType
  status      TicketStatus @default(OPEN)
  title       String       @db.VarChar(200)
  description String       @db.VarChar(5000)
  nickname    String?      @db.VarChar(100)
  email       String?      @db.VarChar(255)
  userId      String?
  trackingId  String       @unique
  priority    Priority?
  assigneeId  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user          User?           @relation(fields: [userId], references: [id])
  assignee      AdminUser?      @relation("AssignedTickets", fields: [assigneeId], references: [id])
  statusHistory StatusHistory[]

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([trackingId])
  @@index([priority])   // Phase 5-1/5-2: speeds up priority-filtered queries
  @@index([assigneeId]) // Phase 5-2: speeds up assignee-filtered queries
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique @db.VarChar(255)
  nickname  String?    @db.VarChar(100)
  createdAt DateTime   @default(now())
  feedbacks Feedback[]
}

model AdminUser {
  id            String          @id @default(cuid())
  email         String          @unique @db.VarChar(255)
  username      String          @unique @db.VarChar(100)
  passwordHash  String
  role          UserRole        @default(ADMIN)
  createdAt     DateTime        @default(now())
  assigned      Feedback[]      @relation("AssignedTickets")
  statusChanges StatusHistory[]
}

model StatusHistory {
  id          String        @id @default(cuid())
  feedbackId  String
  fromStatus  TicketStatus?
  toStatus    TicketStatus
  changedById String?
  note        String?       @db.VarChar(500)
  createdAt   DateTime      @default(now())

  feedback  Feedback   @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  changedBy AdminUser? @relation(fields: [changedById], references: [id])

  @@index([feedbackId])
}
