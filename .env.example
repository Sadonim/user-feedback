# Database (Supabase)
DATABASE_URL=""
DIRECT_URL=""

# Auth (NextAuth v5)
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# CORS — allowlist (쉼표로 구분, 프로덕션 필수)
# 예: CORS_ALLOWED_ORIGINS="https://your-app.com,https://www.your-app.com"
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# CORS — 공개 피드백 엔드포인트 전체 허용 (위젯 임베드 시 true)
# 기본값: false (보수적). 임의 외부 사이트에 위젯 임베드 시 true로 변경
CORS_PUBLIC_OPEN=false

# Rate Limiting (Upstash Redis) — Phase 4
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Email (Phase 4)
RESEND_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
